# Connectivity contract. Every var below is REQUIRED and has no default: a missing
# one makes the test FAIL with a clear ConfigError (it does not skip, and never
# silently defaults to a magic value). To run a subset, select those tests by path
# or -k — each engine asserts only the vars it actually uses, so a BigQuery-only
# test runs with just the GCP_* vars set. (The commented-out RDBMS/egress/service
# blocks further down are genuinely-optional external features, gated separately.)
# Copy to `.env` and fill in for your sandbox.

# --- GCP / BigQuery ---
# How many target datasets a migration uses is the CUSTOMER's choice — the harness
# validates whichever datasets a spec names (target_dataset is a per-suite param,
# opaque to the harness). This fixture needs only two: _1 = canonical (all migrated
# tables; gets the exact-table-count assertion), _2 = harness working space
# (bulk-load/ELT/negative scratch, kept out of _1 so its count stays exact).
GCP_PROJECT=platform-playground-test1   # sandbox project for meta-validation
BQ_LOCATION=US
BQ_DATASET_1=bq_1
BQ_DATASET_2=bq_2
# GOOGLE_APPLICATION_CREDENTIALS=        # or rely on `gcloud auth application-default login`

# --- Legacy Impala / Hive (bundled on one VM; SPEC §9.0) ---
IMPALA_HOST=34.122.57.156                # impala-claude ext IP (codex: 35.223.227.9)
IMPALA_PORT=21050                        # Impala HS2 — NoSASL, analytic reads / validation
HIVE_PORT=10000                          # Hive HS2 — NoSASL, writes / seeding (same host as IMPALA_HOST)
IMPALA_AUTH=NONE                         # golden image is NoSASL; KERBEROS|LDAP for real legacy
# KRB5_KEYTAB=  KRB5_PRINCIPAL=          # if IMPALA_AUTH=KERBEROS
SOURCE_DATABASE=                         # the legacy source database (Hive db holding the source tables)

# --- Source RDBMS (federated query sources; High tier, not P0) ---
# ORACLE_DSN=  ORACLE_USER=  ORACLE_PASSWORD=
# MSSQL_DSN=   MSSQL_USER=   MSSQL_PASSWORD=
# MYSQL_DSN=   MYSQL_USER=   MYSQL_PASSWORD=
# PG_DSN=      PG_USER=      PG_PASSWORD=

# --- Sandbox GCS (bulk-load staging P0-2, egress P0-7) ---
SANDBOX_BUCKET=                          # e.g. dmtemplate-claude-sandbox (bare name)
EGRESS_GCS_BUCKET=                       # e.g. gs://dmtemplate-claude-sandbox/egress
# EGRESS_MSSQL_DSN=  EGRESS_PG_DSN=  SFTP_HOST=  PGP_PRIVATE_KEY_SECRET=

# --- GCP services (Low tier; DAG/monitoring) ---
# COMPOSER_ENV=  COMPOSER_REGION=  SECRET_MANAGER_PREFIX=  TEAMS_WEBHOOK_SECRET=
